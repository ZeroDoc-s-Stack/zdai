# Required: Anthropic API key for claude CLI invocations
ANTHROPIC_API_KEY=

# Required: OpenRouter key (used when provider=openrouter in zdai-state.json)
OPENROUTER_API_KEY=

# Required at container startup: GitHub token to clone zerodoctor/zdclaude
# into /root/.claude. Needs repo read scope on zerodoctor/zdclaude.
GITHUB_TOKEN=

# Optional overrides (defaults shown)
VAULT_DIR=/mnt/local/syncthing/data1
STATE_DIR=/state
TASKNOTES_MCP_URL=http://host.containers.internal:8080/mcp
ZDCLAUDE_REPO=https://github.com/ZeroDoctor/zdclaude
